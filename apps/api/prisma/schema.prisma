generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
}

model Worker {
  id             String       @id @default(cuid())
  fullName       String
  nationality    String
  visaType       String
  visaExpiryDate DateTime
  status         WorkerStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
}
